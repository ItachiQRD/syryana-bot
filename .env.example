# Token du bot : https://discord.com/developers/applications
DISCORD_TOKEN=votre_token_ici

# ID de l'application (Client ID) — pour déployer les commandes slash
CLIENT_ID=votre_client_id

# ID du serveur Syryana (guild) — recommandé pour déploiement instantané des commandes
GUILD_ID=votre_serveur_id

# Salon où poster le quiz quotidien (ID du channel)
QUIZ_CHANNEL_ID=

# Salon annonces / bienvenue Syryana
WELCOME_CHANNEL_ID=

# Salon classement hebdomadaire
LEADERBOARD_CHANNEL_ID=

# Rôle Syryana VIP — multiplicateur XP x1.5 + lecteur /musique (salons vocaux)
VIP_ROLE_ID=

# === Vérification à l'entrée (questionnaire obligatoire) ===
# Rôle "Non vérifié" — accès UNIQUEMENT au salon vérification
UNVERIFIED_ROLE_ID=
# Rôle "Membre" — accès complet après questionnaire réussi
MEMBER_ROLE_ID=
# Salon #vérification avec le bouton "Commencer"
VERIFICATION_CHANNEL_ID=

# Salon suggestions (/suggestion)
SUGGESTIONS_CHANNEL_ID=

# Fuseau pour les routines (Europe/Paris par défaut via TZ)
TZ=Europe/Paris

# Heure du quiz quotidien (0-23)
QUIZ_HOUR=20
QUIZ_MINUTE=0
